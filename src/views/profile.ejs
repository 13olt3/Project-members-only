<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title%>
  </title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <div class="dash-board">
    <div>
      <%= title%>
        <div>This is <%= locals.user.first_name%>'s profile</div>
        <div>You are currently <%= locals.user.member_status ? "is" : "is not" %> a special member </div>
    </div>

    <div><%- include('partials/navbar') %></div>
  </div>



  <div class="main-content">
    <% if (!locals.user?.member_status) {%>
      <div>Answer this correctly to become a special member.</div>
      <form method="POST" action="/becomeMember" autocomplete="off">
        <label for="question">What is 1+1:</label>
        <input type="text" id="question" name="question">

        <button> SUBMIT</button>
      </form>
      <%}%>
  </div>





</body>

</html>