<% if (locals.messages) {%>
  <div class="messages">
    <% messages.forEach((message)=> { %>
      <div class="message-card">
        <% if(locals.user && locals.user.member_status){ %>
          <div>
            Author: <%=locals.user.first_name%>
          </div>
          <%}%>

            <p>Message details:</p>
            <p>
              <%= message.message %>
            </p>

            <% if(locals.user && locals.user.member_status){ %>
              <div>
                Date created: <%=message.date%>
              </div>
              <%}%>

                <% if (locals.user && locals.user.is_admin){ %>
                  <a href="delete/<%=message.id%>"
                    onclick="return confirm('Are you sure you want to delete this message? This cannot be undone.')">Delete
                    Message</a>
                  <%}%>
      </div>

      <% }); %>
  </div>
  <% } %>